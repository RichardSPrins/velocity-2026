---
import Card from '@/components/ui/data-display/Card/Card.astro';

interface Props {
  quote: string;
  name: string;
  role: string;
  avatar: string;
  rating?: number;
}

const { quote, name, role, avatar, rating = 5 } = Astro.props;
---

<Card variant="default" padding="lg" class="flex flex-col gap-4">
  <!-- Stars -->
  <div class="flex gap-0.5">
    {
      Array.from({ length: 5 }).map((_, i) => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class:list={['size-5', i < rating ? 'text-brand-500' : 'text-surface-subtle']}
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
  </div>

  <!-- Quote -->
  <p class="text-foreground-secondary flex-1 text-sm leading-relaxed">"{quote}"</p>

  <!-- Attribution -->
  <div class="flex items-center gap-3">
    <img
      src={avatar}
      alt={name}
      class="ring-surface-subtle size-10 rounded-full object-cover ring-2"
    />
    <div>
      <p class="text-sm font-semibold">{name}</p>
      <p class="text-foreground-muted text-xs">{role}</p>
    </div>
  </div>
</Card>
